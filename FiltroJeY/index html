<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
  <title>Câmera com Moldura</title>
  <style>
    :root {
      --accent: #b85828;
      --primary: #b85828;
      --bg-overlay: rgba(0, 0, 0, 0.45);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      margin: 0;
      background: #000;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #fff;
      overflow: hidden;
      width: 100vw;
      height: 100vh;
      height: 100dvh;
    }

    .frame {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
    }

    .stage {
      position: relative;
      width: 100%;
      height: 100%;
      max-width: 100%;
      overflow: hidden;
      background: #111;
    }

    video, #molduraPreview, #canvasPreview {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    video {
      transform: scaleX(1);
      transition: transform 0.3s;
    }

    video.mirrored {
      transform: scaleX(-1);
    }

    #molduraPreview {
      pointer-events: none;
      z-index: 5;
    }

    #canvasPreview {
      display: none;
      z-index: 6;
      background: #000;
    }

    .ui-layer {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 20;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px;
    }

    .top-bar {
      display: flex;
      justify-content: flex-end;
      pointer-events: auto;
    }

    .controls-bottom {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      pointer-events: auto;
      padding-bottom: 20px;
    }

    .btn {
      padding: 12px 18px;
      font-size: 14px;
      font-weight: 700;
      border: none;
      border-radius: 18px;
      background: var(--accent);
      color: #fff;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(184, 88, 40, 0.35);
      transition: transform 0.15s ease, opacity 0.15s ease;
    }

    .btn:active {
      transform: scale(0.97);
    }

    .btn:hover {
      opacity: 0.95;
    }

    #captureBtn {
      width: 82px;
      height: 82px;
      border-radius: 50%;
      border: 4px solid #fff;
      background: var(--accent);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.1s;
      box-shadow: 0 10px 28px rgba(184, 88, 40, 0.45);
    }

    #captureBtn:active {
      transform: scale(0.95);
    }

    #captureBtn svg {
      width: 36px;
      height: 36px;
      fill: #fff;
    }

    #startScreen {
      position: absolute;
      inset: 0;
      background: #000;
      z-index: 50;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      text-align: center;
      padding: 20px;
    }

    #startBtn {
      padding: 18px 32px;
      font-size: 20px;
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 50px;
      font-weight: bold;
      cursor: pointer;
      box-shadow: 0 10px 28px rgba(184, 88, 40, 0.4);
    }

    #postCaptureActions {
      display: none;
      flex-direction: column;
      gap: 12px;
      width: 100%;
      max-width: 300px;
      pointer-events: auto;
    }

    .action-btn {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      border: none;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      display: inline-block;
      background: var(--accent);
      color: #fff;
      box-shadow: 0 8px 20px rgba(184, 88, 40, 0.35);
    }

    .btn-new {
      background: #6a6a6a;
      box-shadow: none;
    }

    .flash {
      position: absolute;
      inset: 0;
      background: #fff;
      opacity: 0;
      pointer-events: none;
      z-index: 10;
      transition: opacity 0.1s;
    }
  </style>
</head>
<body>

  <div class="frame">
    <div class="stage" id="stage">
      <video id="camera" autoplay playsinline muted></video>
      <canvas id="canvasPreview"></canvas>
      <img id="molduraPreview" alt="" src="moldura1.png" />
      <div class="flash" id="flash"></div>

      <div class="ui-layer" id="cameraUI" style="display: none;">
        <div class="top-bar">
          <button class="btn" id="switchBtn">🔄 Trocar Câmera</button>
        </div>

        <div class="controls-bottom">
          <button id="captureBtn" aria-label="Tirar Foto">
            <svg viewBox="0 0 24 24">
              <path d="M12 9c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
              <path d="M20 5h-3.17L15 3H9L7.17 5H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 14H4V7h16v12z"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="ui-layer" id="resultUI" style="display: none; justify-content: flex-end; align-items: center;">
        <div id="postCaptureActions">
          <a id="downloadBtn" class="action-btn" download="foto_moldura.png">📥 Baixar Imagem</a>
          <button id="shareBtn" class="action-btn">📤 Compartilhar</button>
          <button id="newPhotoBtn" class="action-btn btn-new">📸 Tirar Outra</button>
        </div>
      </div>
    </div>
  </div>

  <div id="startScreen">
    <h2 style="margin-bottom:0">Câmera com Moldura</h2>
    <p style="color:#cfcfcf; margin-top:5px">Toque para iniciar</p>
    <button id="startBtn">INICIAR CÂMERA</button>
    <p id="errorMsg" style="color:#ff8e8e; font-size:12px; max-width:80%;"></p>
  </div>

  <canvas id="canvasFinal" style="display: none;"></canvas>

  <script>
    const MOLDURA_URL = 'moldura1.png';
    let usingFrontCamera = true;
    let stream = null;
    let isCapturing = false;

    const video = document.getElementById('camera');
    const stage = document.getElementById('stage');
    const canvasPreview = document.getElementById('canvasPreview');
    const ctxPreview = canvasPreview.getContext('2d');
    const canvasFinal = document.getElementById('canvasFinal');
    const ctxFinal = canvasFinal.getContext('2d');
    const molduraPreview = document.getElementById('molduraPreview');

    const startScreen = document.getElementById('startScreen');
    const cameraUI = document.getElementById('cameraUI');
    const resultUI = document.getElementById('resultUI');
    const postCaptureActions = document.getElementById('postCaptureActions');
    const errorMsg = document.getElementById('errorMsg');

    document.getElementById('startBtn').addEventListener('click', initCamera);
    document.getElementById('switchBtn').addEventListener('click', switchCamera);
    document.getElementById('captureBtn').addEventListener('click', takePhoto);
    document.getElementById('newPhotoBtn').addEventListener('click', resetCamera);

    molduraPreview.src = MOLDURA_URL;

    async function initCamera() {
      if (stream) {
        stream.getTracks().forEach(track => track.stop());
      }

      const constraints = {
        audio: false,
        video: {
          facingMode: usingFrontCamera ? 'user' : 'environment'
        }
      };

      try {
        stream = await navigator.mediaDevices.getUserMedia(constraints);
        video.srcObject = stream;

        if (usingFrontCamera) {
          video.classList.add('mirrored');
        } else {
          video.classList.remove('mirrored');
        }

        video.onloadedmetadata = () => {
          video.play();
          startScreen.style.display = 'none';
          cameraUI.style.display = 'flex';
        };

      } catch (err) {
        console.error("Erro Câmera:", err);
        errorMsg.innerText = "Erro ao acessar câmera: " + err.name;

        try {
          stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });
          video.srcObject = stream;
          video.play();
          startScreen.style.display = 'none';
          cameraUI.style.display = 'flex';
        } catch (e) {
          alert("Não foi possível acessar a câmera.");
        }
      }
    }

    async function switchCamera() {
      usingFrontCamera = !usingFrontCamera;
      await initCamera();
    }

    async function takePhoto() {
      if (isCapturing) return;
      isCapturing = true;

      const flash = document.getElementById('flash');
      flash.style.opacity = '1';
      setTimeout(() => flash.style.opacity = '0', 150);

      canvasFinal.width = 1080;
      canvasFinal.height = 1920;

      drawVideoToCanvas(ctxFinal, canvasFinal.width, canvasFinal.height);
      await drawImageLayer(ctxFinal, MOLDURA_URL, canvasFinal.width, canvasFinal.height);

      canvasPreview.width = stage.clientWidth;
      canvasPreview.height = stage.clientHeight;
      ctxPreview.drawImage(canvasFinal, 0, 0, canvasPreview.width, canvasPreview.height);

      video.style.display = 'none';
      molduraPreview.style.display = 'none';
      canvasPreview.style.display = 'block';

      cameraUI.style.display = 'none';
      resultUI.style.display = 'flex';
      postCaptureActions.style.display = 'flex';

      prepareDownloadAndShare();
      isCapturing = false;
    }

    function drawVideoToCanvas(ctx, targetW, targetH) {
      const vidW = video.videoWidth;
      const vidH = video.videoHeight;

      const videoRatio = vidW / vidH;
      const canvasRatio = targetW / targetH;

      let drawW, drawH, startX, startY;

      if (videoRatio > canvasRatio) {
        drawH = targetH;
        drawW = targetH * videoRatio;
        startX = (targetW - drawW) / 2;
        startY = 0;
      } else {
        drawW = targetW;
        drawH = targetW / videoRatio;
        startX = 0;
        startY = (targetH - drawH) / 2;
      }

      ctx.save();
      ctx.drawImage(video, startX, startY, drawW, drawH);
      ctx.restore();
    }

    function drawImageLayer(ctx, url, w, h) {
      return new Promise(resolve => {
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.onload = () => {
          ctx.drawImage(img, 0, 0, w, h);
          resolve();
        };
        img.onerror = resolve;
        img.src = url;
      });
    }

    function resetCamera() {
      canvasPreview.style.display = 'none';
      video.style.display = 'block';
      molduraPreview.style.display = 'block';
      resultUI.style.display = 'none';
      cameraUI.style.display = 'flex';
    }

    function prepareDownloadAndShare() {
      const downloadBtn = document.getElementById('downloadBtn');
      const shareBtn = document.getElementById('shareBtn');

      const dataUrl = canvasFinal.toDataURL('image/png');
      downloadBtn.href = dataUrl;

      shareBtn.onclick = async () => {
        canvasFinal.toBlob(async (blob) => {
          if (!blob) return;
          const file = new File([blob], "foto_evento.png", { type: "image/png" });

          if (navigator.share && navigator.canShare({ files: [file] })) {
            try {
              await navigator.share({
                files: [file],
                title: 'Foto com Moldura',
                text: 'Olha minha foto!'
              });
            } catch (error) {
              console.log('Compartilhamento cancelado', error);
            }
          } else {
            alert("Seu navegador não suporta compartilhamento direto. Baixando a imagem...");
            downloadBtn.click();
          }
        }, 'image/png');
      };
    }
  </script>
</body>
</html>
